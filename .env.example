# 1inch Developer Portal API key (https://business.1inch.com/portal/applications)
ONEINCH_API_KEY=

# 1inch Commercial API ToU: end-user wallet for /quote calls (no per-request
# sender). /swap and /fusion automatically use the per-request `sender` as
# origin. Leave empty to omit origin on /quote (less compliant).
INCH_ORIGIN=

# Default wallet address for quotes (optional, can connect via Rabby in UI)
DEFAULT_SENDER=

# Fynd server URL (default: http://localhost:3000)
# FYND_URL=http://localhost:3000

# Server port (default: 8899)
# PORT=8899
